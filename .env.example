# --- Backend selector
# "huggingface"  -> uses HuggingFace Inference API  (free tier available)
# "litellm"      -> routes through LiteLLM to any provider
LLM_BACKEND=huggingface

# --- HuggingFace Inference API
# Get your token at https://huggingface.co/settings/tokens
#
# Model options (set HF_MODEL to override the default):
#   Qwen/Qwen2.5-7B-Instruct           (default - free HF serverless, good JSON)
#   Qwen/Qwen2.5-72B-Instruct          (best quality, but routes via deepinfra -
#                                        requires HF Pro or provider access)
#   meta-llama/Llama-3.1-8B-Instruct   (free HF serverless)
#   mistralai/Mistral-7B-Instruct-v0.3 (free HF serverless)
#
# If you get a 403 "provider not available" error, the model was routed to a
# third-party provider (deepinfra, together.ai, etc.) that you have not enabled.
# Two ways to fix it:
#   1. Enable the provider at huggingface.co/settings/inference-providers
#   2. Set HF_PROVIDER below to pin a specific provider (or "hf-inference" for
#      HF's own infrastructure, which only hosts smaller models for free)
HF_TOKEN=hf_REPLACE_ME
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# HF_PROVIDER=deepinfra

# --- LiteLLM
# Model string follows LiteLLM format: provider/model-name
# Examples: gpt-4o-mini, anthropic/claude-haiku-4-5, groq/llama3-8b-8192,
#           ollama/mistral (for local Ollama)
LITELLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-REPLACE_ME
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# GROQ_API_KEY=gsk_REPLACE_ME

# --- Academic APIs
# Semantic Scholar - no key needed for basic use, but register for higher limits
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
